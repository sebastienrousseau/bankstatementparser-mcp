{
  "$schema": "https://glama.ai/api/mcp/v1/schemas/glama.json",
  "maintainers": ["sebastienrousseau"],
  "title": "bankstatementparser-mcp",
  "display_name": "BankStatementParser MCP",
  "description": "Model Context Protocol server for the bankstatementparser bank statement parsing library. Exposes five tools spanning format discovery, format detection, statement parsing into structured transactions, dry-run validation, and statement summaries across ISO 20022 CAMT.053, pain.001, SWIFT MT940, OFX, QFX, and CSV inputs. 100% line + branch coverage.",
  "version": "0.0.11",
  "repository": "https://github.com/sebastienrousseau/bankstatementparser-mcp",
  "homepage": "https://bankstatementparser.com",
  "license": "Apache-2.0",
  "language": "Python",
  "runtime": "python",
  "categories": ["finance"],
  "tags": [
    "bank-statement",
    "bankstatementparser",
    "camt053",
    "mt940",
    "ofx",
    "qfx",
    "csv",
    "iso20022",
    "statement-parsing",
    "transactions",
    "reconciliation",
    "fastmcp",
    "financial-services",
    "fintech"
  ],
  "mcpServers": {
    "bankstatementparser": {
      "command": "bankstatementparser-mcp"
    }
  },
  "installation": {
    "pip": "pip install bankstatementparser-mcp",
    "docker": "docker run --rm -i ghcr.io/sebastienrousseau/bankstatementparser-mcp:0.0.11"
  }
}
